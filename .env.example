# ---------------------------------------------------------------------------
# Polymarket HFT Trading Bot - environment template
# Copy to .env and fill in real values. NEVER commit .env.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
LOG_LEVEL=info

# Redis (used by all bots via packages/bus)
REDIS_URL=redis://localhost:6379
REDIS_NAMESPACE=polymarket

# Polymarket CLOB (Bot Tape Reader, Bot Executor)
POLYMARKET_CLOB_HTTP_URL=https://clob.polymarket.com
POLYMARKET_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws
POLYMARKET_CHAIN_ID=137

# Polygon RPC (Bot Executor only)
# In `simulation` mode the private key is OPTIONAL — the simulator never
# touches the chain. In `live` mode you MUST provide a real EOA private key
# (>=64 hex chars). NEVER commit a real key.
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_PRIVATE_KEY=
POLYGON_PROXY_WALLET=

# Oracle providers (Bot Oracle)
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
SPORTRADAR_API_KEY=Ll02H2wgjcEZn896FOKcR8cRsYdKQs0rV4hyEZPY
NEWS_API_KEY=c66ca80e358749c19627c7dbbdf94399
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAKX29AEAAAAAaTBSeaGOMk4bWDv5nkEJJ57eA1U%3DpYavCl7em66HcYCY0v9QjEN9Msvtm1N617TC1cYjKGTOh1wlrK

# Risk limits (Bot Strategist / Bot Executor)
MAX_CAPITAL_PER_TRADE_USDC=50
DAILY_STOP_LOSS_USDC=100
MAX_INVENTORY_PERCENT=10
MIN_GAS_BALANCE_MATIC=5

# Health endpoints
HEALTH_PORT_ORACLE=7001
HEALTH_PORT_TAPE_READER=7002
HEALTH_PORT_STRATEGIST=7003
HEALTH_PORT_EXECUTOR=7004
HEALTH_PORT_DASHBOARD_GATEWAY=7005

# Bot Tape Reader (Polymarket CLOB)
# Leave TAPE_READER_TOKEN_IDS empty to auto-discover the top markets via /sampling-markets.
# Manual format: TAPE_READER_TOKEN_IDS=tokenIdA:YES@conditionId1,tokenIdB:NO@conditionId1
TAPE_READER_TOKEN_IDS=
TAPE_READER_AUTO_DISCOVER_LIMIT=5
TAPE_READER_POLL_INTERVAL_MS=3000
TAPE_READER_MAX_LEVELS=15
# Mode: ws (default, real-time WebSocket), rest (polling), both (REST warmup + WS).
TAPE_READER_MODE=ws
# Set to true to receive best_bid_ask, new_market and market_resolved events.
TAPE_READER_WS_CUSTOM_FEATURE=false

# Bot Strategist (analyzers + dedupe)
# Production defaults shown here. For dev (sub-1¢ spreads on Polymarket),
# lower SUM_TO_ONE_EDGE to 0.001, SPREAD_MIN to 0.005 and NEWS_MIN_IMPACT to 0.05.
STRATEGIST_SUM_TO_ONE_EDGE=0.01
STRATEGIST_SPREAD_MIN=0.04
STRATEGIST_SIGNAL_TTL_MS=5000
STRATEGIST_DEDUPE_PRICE_EPSILON=0.005
STRATEGIST_MIN_REPEAT_INTERVAL_MS=500
# News-arb analyzer (consume oracle:signals)
STRATEGIST_NEWS_MIN_IMPACT=0.4
STRATEGIST_NEWS_TTL_MS=8000
# Auto-execution bridge (signal -> executor:orders, post-only). Default off.
STRATEGIST_AUTOEXECUTE=false
STRATEGIST_AUTOEXEC_MAX_SIZE_USDC=20
STRATEGIST_AUTOEXEC_TTL_MS=5000

# Bot Oracle (Binance feeds)
ORACLE_BINANCE_ENABLED=true
ORACLE_BINANCE_SYMBOLS=btcusdt,ethusdt,solusdt
ORACLE_BINANCE_WINDOW_MS=60000
ORACLE_BINANCE_MIN_DELTA_PCT=0.5
ORACLE_BINANCE_SATURATION_PCT=2.5
ORACLE_BINANCE_COOLDOWN_MS=5000

# Bot Executor
# Mode: simulation (no chain access, default) | live (requires POLYGON_PRIVATE_KEY).
# Live mode is currently a safe stub that rejects every order with
# `live_mode_not_yet_implemented` until the CLOB signer lands.
EXECUTOR_MODE=simulation
EXECUTOR_TAKER_FEE_BPS=20
EXECUTOR_MAKER_FEE_BPS=0
EXECUTOR_DEFAULT_TTL_MS=15000
EXECUTOR_MAX_OPEN_ORDERS=200
EXECUTOR_LATENCY_MIN_MS=50
EXECUTOR_LATENCY_JITTER_MS=250
EXECUTOR_SWEEP_INTERVAL_MS=1000

# Tape Reader metadata refresh interval (ms). Defaults to 5 minutes.
TAPE_READER_METADATA_INTERVAL_MS=300000
